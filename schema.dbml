Enum enum_plan_recurrence { monthly quarterly annual biennial one_time none }
Enum enum_price_recurrence { monthly quarterly annual biennial one_time }
Enum enum_location_mode { presencial online hibrido }
Enum enum_lead_objective { iniciante intermediario avancado prova_especifica retorno emagrecimento outro }
Enum enum_lead_experience { nunca_correu_ate_5km_5_a_10km_10_a_21km mais_de_21km maratona }
Enum enum_lead_status { new contacted visit_scheduled converted lost }
Enum enum_outbox_status { pending processing processed failed }
Enum enum_communication_kind { welcome follow_up renewal_reminder dunning churn_prevention payment_failed trial_ending other }
Enum enum_communication_status { queued sent delivered opened bounced failed }
Enum enum_communication_trigger { lead_created lead_no_response_72h subscription_payment_failed subscription_upcoming_renewal tenant_welcomed athlete_inactive other }
Enum enum_event_type { rua trail revezamento treinao clinica viagem }
Enum enum_event_source { managed imported suggested }
Enum enum_event_status { queue published archived }
Enum enum_agent_kind { general site_editor report_writer suggestion onboarding athlete_assistant }
