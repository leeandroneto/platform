Enum enum_risk_level { low medium high critical }
Enum enum_engine_plan_status { pending approved rejected applied error }
Enum enum_pipeline_stage { plan generate verify persist done error }
Enum enum_plan_audience { tenant sponsor supplier }
Enum enum_plan_contract { none monthly annual biennial }
Enum enum_feature_kind { boolean quota enum_kind }
Enum enum_subscription_status { trialing active past_due canceled paused }
Enum enum_gateway { asaas pagarme stone efi }
Enum enum_sponsor_tier { estadual nacional oficial }
Enum enum_placement_surface { marquee brand_page feed }
Enum enum_coupon_owner { retake sponsor }
Enum enum_affiliate_program { awin rakuten direct }
Enum enum_coupon_status { pending approved live archived }
Enum enum_resource_kind { location room space equipment }
Enum enum_ownership { owned rented partner }
Enum enum_resource_status { active inactive maintenance }
Enum enum_commission_status { pending paid voided }
Enum enum_booking_status { confirmed cancelled completed no_show }
Enum enum_horizon { now next later }
Enum enum_roadmap_status { idea planned in_progress shipped }
Enum enum_changelog_type { novo melhoria em_breve }
Enum enum_athlete_status { active paused canceled overdue }
Enum enum_athlete_level { beginner intermediate advanced elite }
Enum enum_threshold_source { test manual wearable }
Enum enum_mesocycle_focus { base build peak transition }
Enum enum_modality { run swim bike triathlon }
Enum enum_session_status { planned executed skipped }
