# ─── App URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# ─── Session ────────────────────────────────────────────────────────────────
SESSION_SECRET=

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── AI (Vercel AI Gateway — único canal) ───────────────────────────────────
VERCEL_AI_GATEWAY_API_KEY=

# ─── Bot protection (BotID — setup via SDK, sem env var) ────────────────────

# ─── Upstash Redis (rate limit + cache) ─────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# ─── Gateway (Asaas / Pagar.me / Stone — JIT no S6) ─────────────────────────
# ASAAS_API_KEY=
# PAGARME_API_KEY=
# STONE_API_KEY=

# ─── Analytics (JIT) ────────────────────────────────────────────────────────
# META_PIXEL_ID=
# META_CAPI_TOKEN=
# GA4_MEASUREMENT_ID=

# ─── Google Fonts API (JIT — theme builder Apoiador font picker catalog) ───
# GOOGLE_FONTS_API_KEY=

# ─── NÃO colocar aqui ───────────────────────────────────────────────────────
# - Credenciais de gateway por tenant: vivem em public.tenant_gateway_credentials (Supabase Vault)
# - Tokens de wearable (Garmin/Strava/etc): vivem em public.wearable_connections (encrypted)
