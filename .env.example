# ─── App URL (varia por deploy: prod / preview / local) ─────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Default brand fallback (emergency only — multi-brand via hostname é o padrão) ─
# Usado SÓ se proxy.ts não conseguir resolver brand do Host header (ADR-0024).
# Em produção normal, brand vem de platform.brands via lookup por hostname.
NEXT_PUBLIC_DEFAULT_BRAND_HOST=desafit.app

# ─── Supabase (1 project compartilhado entre todas as marcas filhas — ADR-0024) ─
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=

# ─── PWA Web Push (1 par por tenant em platform.push_subscriptions — RFC 8292) ─
# Vapid GLOBAL (fallback). Por tenant fica em DB, não env.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@platform.example

# ─── Email (Resend — 1 conta multi-domain) ──────────────────────────────────
RESEND_API_KEY=

# ─── Observability (1 org, 1 projeto Sentry/PostHog compartilhados) ─────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── AI (Vercel AI Gateway — reusa entre todas as marcas filhas) ────────────
VERCEL_AI_GATEWAY_API_KEY=
# direct provider fallback
ANTHROPIC_API_KEY=

# ─── WhatsApp (1 conta Meta compartilhada) ──────────────────────────────────
WHATSAPP_CLOUD_TOKEN=

# ─── Billing plataforma → profissional (EFI Bank — 1 conta) ─────────────────
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_CERT_PATH=

# ─── Analytics (1 conta cada) ────────────────────────────────────────────────
META_PIXEL_ID=
META_CAPI_TOKEN=
GA4_MEASUREMENT_ID=

# ─── NÃO colocar aqui ────────────────────────────────────────────────────────
# - Brand name/domain/parent: vivem em platform.brands (ADR-0024), resolvidos
#   por hostname no proxy.ts. Adicionar nova marca filha = INSERT + DNS.
# - Vars do profissional (Asaas/Pagar.me/MP keys do prof): vivem em
#   platform.tenant_gateway_credentials (Supabase Vault), nunca no env.
