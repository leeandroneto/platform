    classDef branchDanger fill:#ffebee,stroke:#c62828
    classDef universal fill:#f5f5f5,stroke:#616161
    class Q1,Q7 decision
    class Safety1,Safety2 safety
    class BranchR branch
    class BranchC branchWarn
    class BranchA branchDanger
    class Basics,PN,Goal,Contact universal
