flowchart TD
    Start([Inicio]) --> Basics[basics - universal]
    Basics --> Q1{Q1 - cycling_phase}
    Q1 -->|never| BranchA["Branch: Primeiro Pedal"]
    Q1 -->|stopped| BranchB["Branch: Retomada"]
    Q1 -->|casual| BranchC["Branch: Estruturar"]
    BranchA --> Q2
    BranchB --> Q2
    BranchC --> Q2
    Q2[Q2 - main_barrier] --> Q3[Q3 - current_activity]
    Q3 --> Q4[Q4 - riding_context]
    Q4 --> Q5[Q5 - available_days]
    Q5 --> Q6{Q6 - health_conditions}
    Q6 -->|none / diabetes / respiratory| Safe[Fluxo normal]
    Q6 -->|cardiac / joint_spine / recent_surgery| Safety["safetyReduced"]
    Safe --> PN
    Safety --> PN
    PN[personal_note - universal] --> Goal[goal - universal] --> Contact[contact - universal] --> End([relatorio IA])

    classDef decision fill:#fff3e0,stroke:#f57c00
    classDef safety fill:#ffebee,stroke:#c62828
    classDef branch fill:#e8f5e9,stroke:#2e7d32
    classDef universal fill:#f5f5f5,stroke:#616161
    class Q1,Q6 decision
    class Safety safety
    class BranchA,BranchB,BranchC branch
    class Basics,PN,Goal,Contact universal
