flowchart TD
    Start([Inicio]) --> Basics[basics - universal]
    Basics --> Q1{Q1 - experience}
    Q1 -->|beginner| BranchInit["Iniciante"]
    Q1 -->|intermediate| Default[Fluxo padrao]
    Q1 -->|advanced| BranchAdv["Avancado"]
    BranchInit --> Q2
    Default --> Q2
    BranchAdv --> Q2
    Q2[Q2 - training_frequency] --> Q3[Q3 - main_challenge]
    Q3 --> Q4[Q4 - sleep_quality]
    Q4 --> Q5[Q5 - eating_consistency]
    Q5 --> Q6{Q6 - health_conditions}
    Q6 -->|none / joint_pain / other| Safe[Fluxo normal]
    Q6 -->|cardiac / spinal / diabetes| Safety["safetyReduced"]
    Safe --> PN
    Safety --> PN
    PN[personal_note - universal] --> Goal[goal - universal] --> Contact[contact - universal] --> End([relatorio IA])

    classDef decision fill:#fff3e0,stroke:#f57c00
    classDef safety fill:#ffebee,stroke:#c62828
    classDef branch fill:#e8f5e9,stroke:#2e7d32
    classDef universal fill:#f5f5f5,stroke:#616161
    class Q1,Q6 decision
    class Safety safety
    class BranchInit,BranchAdv branch
    class Basics,PN,Goal,Contact universal
